{
  "name": "midoumao",
  "version": "0.2.4",
  "description": "midou（咪豆）— 一只拥有灵魂的 AI 伙伴，以我心爱的公狸花猫命名",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "midou": "dist/index.js"
  },
  "files": [
    "dist/",
    "web/dist/",
    "workspace/SOUL.md",
    "workspace/HEARTBEAT.md",
    "workspace/system.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev:backend": "npx tsx src/index.ts",
    "dev:frontend": "cd web && npm run dev",
    "dev": "concurrently -k -n backend,frontend \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "tsc && cd web && npm run build",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "npx tsx --test test/test-unit.ts",
    "test:rag": "npx tsx --test test/test-rag.ts",
    "test:api": "npx tsx --test test/test-api.ts",
    "test:all": "npx tsx --test test/"
  },
  "keywords": [
    "ai",
    "soul",
    "companion",
    "midou",
    "cat"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smilesand/midou.git"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@parcel/watcher": "^2.5.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "openai": "^6.24.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "@types/node-cron": "^3.0.11",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
